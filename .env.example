# Optional direct provider API mode.
# Codex CLI / Gemini CLI users do not need API keys for local runtime usage.
IMAGE_AGENT_GEMINI_API_KEY=your_google_ai_studio_key
IMAGE_AGENT_OPENAI_API_KEY=your_openai_api_key

# Optional provider routing
# IMAGE_AGENT_PROVIDER=gemini
# IMAGE_AGENT_PROVIDER=openai
# IMAGE_AGENT_MODEL=gemini-3.1-flash-image-preview
# IMAGE_AGENT_OPENAI_MODEL=gpt-image-1.5

# Single-user private mode
IMAGE_AGENT_PRIVATE_TOKEN=replace_with_a_long_random_token

# Optional API settings
IMAGE_AGENT_API_PORT=3456
IMAGE_AGENT_RATE_LIMIT_MAX=30
IMAGE_AGENT_RATE_LIMIT_WINDOW_MS=60000
