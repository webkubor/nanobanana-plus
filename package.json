{
  "name": "nanobanana-extension",
  "version": "1.5.0",
  "type": "module",
  "description": "Gemini CLI extension for Nano Banana models",
  "packageManager": "pnpm@10.25.0",
  "bin": {
    "nanobanana-extension": "./bin/nanobanana-plus.js",
    "nanobanana-plus": "./bin/nanobanana-plus.js"
  },
  "files": [
    "bin",
    "commands",
    "GEMINI.md",
    "LICENSE",
    "README.md",
    "README.en.md",
    "gemini-extension.json",
    "mcp-server/dist",
    "mcp-server/package.json",
    "setup.sh"
  ],
  "scripts": {
    "build": "node ./scripts/run-tsc.mjs -p mcp-server/tsconfig.json",
    "dev": "node ./scripts/run-tsc.mjs -p mcp-server/tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings 0",
    "typecheck": "node ./scripts/run-tsc.mjs -p mcp-server/tsconfig.json --noEmit",
    "test": "pnpm --dir mcp-server test",
    "clean": "rm -rf mcp-server/dist && rm -rf node_modules && rm -rf mcp-server/node_modules",
    "preflight": "pnpm run clean && pnpm install && pnpm run format && pnpm run lint || true && pnpm run build && pnpm run typecheck",
    "prepack": "pnpm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-license-header": "^0.8.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.30.1"
  }
}
