{
  "name": "image-agent-plus",
  "version": "2.0.0",
  "type": "module",
  "description": "Local-first image agent workflow for Codex CLI, Gemini CLI, OpenClaw, and Hermes",
  "packageManager": "pnpm@10.25.0",
  "bin": {
    "image-agent-plus": "./bin/image-agent-plus.js"
  },
  "files": [
    "bin",
    "commands",
    "skills",
    "GEMINI.md",
    "LICENSE",
    "README.md",
    "README.en.md",
    "mcp-server/dist",
    "mcp-server/package.json",
    "setup.sh"
  ],
  "scripts": {
    "build": "node ./scripts/run-tsc.mjs -p mcp-server/tsconfig.json",
    "dev": "node ./scripts/run-tsc.mjs -p mcp-server/tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings 0",
    "typecheck": "node ./scripts/run-tsc.mjs -p mcp-server/tsconfig.json --noEmit",
    "test": "pnpm --dir mcp-server test",
    "clean": "rm -rf mcp-server/dist && rm -rf node_modules && rm -rf mcp-server/node_modules",
    "preflight": "pnpm run clean && pnpm install && pnpm run format && pnpm run lint || true && pnpm run build && pnpm run typecheck",
    "prepack": "pnpm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.17.0"
  },
  "devDependencies": {
    "@eslint-community/eslint-utils": "4.9.1",
    "@eslint/js": "9.39.3",
    "@types/node": "^22.0.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-license-header": "^0.8.0",
    "eslint-visitor-keys": "3.4.3",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.30.1"
  }
}
