{
  "name": "nanobanana-extension",
  "version": "1.3.0",
  "type": "module",
  "description": "Gemini CLI extension for Nano Banana models",
  "bin": {
    "nanobanana-extension": "./bin/nanobanana-plus.js",
    "nanobanana-plus": "./bin/nanobanana-plus.js"
  },
  "files": [
    "bin",
    "commands",
    "GEMINI.md",
    "LICENSE",
    "README.md",
    "README.zh-CN.md",
    "gemini-extension.json",
    "mcp-server/dist",
    "mcp-server/package.json",
    "mcp-server/package-lock.json",
    "scripts/postinstall.mjs",
    "setup.sh"
  ],
  "scripts": {
    "build": "npm --prefix mcp-server run build",
    "install-deps": "npm --prefix mcp-server install",
    "dev": "npm --prefix mcp-server run dev",
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings 0",
    "typecheck": "npm --prefix mcp-server run typecheck",
    "test": "npm --prefix mcp-server run test",
    "clean": "rm -rf mcp-server/dist && rm -rf node_modules",
    "preflight": "npm run clean && npm ci && npm run format && npm run lint || true && npm run build && npm run typecheck",
    "prepack": "npm run build",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-license-header": "^0.8.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.30.1"
  }
}